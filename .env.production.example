# Скопируйте в .env.production на сервере (не коммитьте секреты).

DOMAIN=arhipovdan.ru

POSTGRES_USER=tinao
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=tinao

DATABASE_URL=postgresql://tinao:change-me-strong@postgres:5432/tinao?schema=public

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong
# Минимум 32 символа (случайная строка)
ADMIN_SESSION_SECRET=replace-with-32-plus-char-random-secret

# Срок сессии админа в часах (1–720), по умолчанию 8
ADMIN_SESSION_TTL_HOURS=8

# Опционально: выполнить seed при каждом старте контейнера app (обычно 0; идемпотентный upsert)
RUN_SEED_ON_DEPLOY=0
# Один раз при пустой БД (нет ни одной группы): seed и выход; при наличии групп — ничего. Не ставьте 1 на каждый деплой без необходимости.
RUN_BOOTSTRAP_IF_EMPTY=0
